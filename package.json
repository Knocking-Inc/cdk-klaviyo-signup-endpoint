{
  "name": "cdk-klavio-signup-endpoint",
  "version": "1.0.0",
  "description": "CDK project for Klaviyo email signup endpoint",
  "main": "bin/cdk-klavio-signup-endpoint.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy",
    "diff": "cdk diff"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.835.0",
    "@aws-sdk/client-secrets-manager": "^3.835.0",
    "@aws-sdk/lib-dynamodb": "^3.835.0",
    "@types/jest": "^29.5.5",
    "@types/node": "20.5.0",
    "aws-cdk": "2.1019.1",
    "axios": "^1.10.0",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "~5.1.6"
  },
  "dependencies": {
    "aws-cdk-lib": "2.202.0",
    "constructs": "^10.2.70",
    "source-map-support": "^0.5.21"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "lambda/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
